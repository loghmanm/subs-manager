<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1" />
  <title>مدیریت مشترکین</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <div class="topbar">
    <div class="brand">
      <div class="signal-mark"><i></i><i></i><i></i><i></i></div>
      <div>
        <div class="brand-title">مدیریت مشترکین</div>
        <div class="brand-sub">کنترل اشتراک و اعلان انقضا</div>
      </div>
    </div>
    <div class="topbar-right">
      <button class="btn btn-ghost" id="btnTestTelegram" title="ارسال پیام آزمایشی به تلگرام">
        تست اتصال تلگرام
      </button>
      <div class="user-chip">
        <span class="dot dot-green dot-pulse"></span>
        <%= username %>
      </div>
      <form method="POST" action="/logout">
        <button class="btn btn-icon" title="خروج" type="submit">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><path d="M16 17l5-5-5-5"/><path d="M21 12H9"/></svg>
        </button>
      </form>
    </div>
  </div>

  <div class="container">

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label"><span class="dot dot-green"></span> کل مشترکین</div>
        <div class="stat-value" id="statTotal">–</div>
      </div>
      <div class="stat-card">
        <div class="stat-label"><span class="dot dot-amber"></span> رو به اتمام (تا ۵ روز)</div>
        <div class="stat-value" id="statSoon">–</div>
      </div>
      <div class="stat-card">
        <div class="stat-label"><span class="dot dot-red"></span> منقضی شده</div>
        <div class="stat-value" id="statExpired">–</div>
      </div>
      <div class="stat-card">
        <div class="stat-label"><span class="dot" style="background:var(--teal);box-shadow:0 0 0 3px var(--teal-soft)"></span> در لیست نظارت</div>
        <div class="stat-value" id="statMonitored">–</div>
      </div>
    </div>

    <div class="toolbar">
      <div class="search-box">
        <input type="text" id="searchInput" placeholder="جستجو بر اساس نام، شناسه، آی‌پی، موبایل یا تاریخ انقضا ..." />
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      </div>

      <div class="tab-switch" id="viewTabs">
        <button data-view="all" class="active">همه <span class="count" id="tabCountAll">0</span></button>
        <button data-view="watch">لیست نظارت <span class="count" id="tabCountWatch">0</span></button>
      </div>

      <button class="btn btn-primary" id="btnAdd">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
        افزودن مشترک
      </button>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>نام مشترک</th>
            <th>شناسه مشترک</th>
            <th>آی‌پی استاتیک</th>
            <th>موبایل</th>
            <th>تاریخ انقضا</th>
            <th>وضعیت</th>
            <th>نظارت</th>
            <th>عملیات</th>
          </tr>
        </thead>
        <tbody id="tableBody">
          <!-- ردیف‌ها با جاوااسکریپت رندر می‌شوند -->
        </tbody>
      </table>
      <div class="empty-state hidden" id="emptyState">
        <div class="signal-mark"><i></i><i></i><i></i><i></i></div>
        <div>موردی برای نمایش یافت نشد</div>
      </div>
    </div>

  </div>

  <!-- مودال افزودن/ویرایش -->
  <div class="modal-overlay hidden" id="modalOverlay">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title" id="modalTitle">افزودن مشترک جدید</div>
        <button class="close-x" id="modalClose">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <form id="subscriberForm">
        <div class="modal-body">
          <input type="hidden" id="subId" />
          <div class="form-grid">
            <div class="field full">
              <label>نام مشترک <span class="required-star">*</span></label>
              <input type="text" id="f_name" required />
            </div>
            <div class="field">
              <label>شناسه مشترک <span class="required-star">*</span></label>
              <input type="text" id="f_subscriber_id" class="mono" required />
            </div>
            <div class="field">
              <label>آی‌پی استاتیک <span class="required-star">*</span></label>
              <input type="text" id="f_ip" class="mono" placeholder="192.168.1.10" required />
            </div>
            <div class="field">
              <label>شماره موبایل <span class="required-star">*</span></label>
              <input type="text" id="f_mobile" class="mono" placeholder="09123456789" required />
            </div>
            <div class="field">
              <label>تاریخ انقضا (شمسی) <span class="required-star">*</span></label>
              <input type="text" id="f_expiry" class="mono" placeholder="1404/05/12" required />
              <div class="hint" id="expiryPreview">&nbsp;</div>
            </div>
            <div class="field full">
              <label>سرویس‌دهنده / یادداشت (اختیاری)</label>
              <input type="text" id="f_provider" />
            </div>
            <div class="field full">
              <label>توضیحات تکمیلی (اختیاری)</label>
              <textarea id="f_note" rows="2"></textarea>
            </div>
          </div>
          <div class="error-text hidden" id="formError"></div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-ghost" id="btnCancel">انصراف</button>
          <button type="submit" class="btn btn-primary" id="btnSave">ذخیره</button>
        </div>
      </form>
    </div>
  </div>

  <div class="toast-wrap" id="toastWrap"></div>

  <script src="/js/jalali-client.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
